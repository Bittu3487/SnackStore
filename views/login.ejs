<%- include('partials/header') %>

<div class="auth-container">
    <div class="auth-box">
        <h2>Welcome Back 👋</h2>
        <p class="auth-sub">Login to continue your snacks journey</p>

        <form action="/user/login" method="POST">
            <div class="form-group">
                <input type="email" name="email" placeholder="Login with Email">
            </div>

            <div class="form-group">
                <input type="password" name="password" placeholder="Password">
            </div>

            <button type="submit" class="auth-btn secondary">Login with Email</button>
        </form>

        <p class="auth-link">
            New here? <a href="/user/register">Create an account</a>
        </p>
    </div>
</div>

<%- include('partials/footer') %>