<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Snack Store - <%= typeof title !=='undefined' ? title : 'Best Snacks Online' %>
    </title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="nav-container">

            <!-- Logo -->
            <div class="nav-logo">
                <a href="/">
                    <i class="fas fa-utensils"></i> SnackStore
                </a>
            </div>

            <!-- Search -->
            <div class="nav-search">
                <form action="/products" method="GET" class="search-form">
                    <input type="text" name="search" placeholder="Search snacks..." class="search-input">
                    <button type="submit" class="search-btn">
                        <i class="fas fa-search"></i>
                    </button>
                </form>
            </div>

            <!-- Links -->
            <div class="nav-links" id="navLinks">
                <a href="/products" class="nav-link">
                    <i class="fas fa-th-large"></i> Products
                </a>

                <a href="/cart" class="nav-link cart-link">
                    <i class="fas fa-shopping-cart"></i>
                    <span class="cart-count" id="cartCount">0</span>
                </a>

                <!-- 🔐 Login / Register -->
                <% if (!user) { %>
                    <a href="/user/login" class="nav-link">
                        <i class="fas fa-sign-in-alt"></i> Login
                    </a>
                    <a href="/user/register" class="nav-link">
                        <i class="fas fa-user-plus"></i> Register
                    </a>
                    <% } else { %>
                        <span class="nav-link">👋 <%= user.name %></span>
                        <a href="/user/logout" class="nav-link">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </a>
                        <% } %>
                            <% if (isAdmin) { %>
                                <!-- 👑 Visible after login -->
                                <a href="/admin/orders" class="nav-link admin-link">
                                    <i class="fas fa-user-shield"></i> Dashboard
                                </a>
                                <a href="/admin/orders" class="nav-link">
                                    📦 Orders
                                </a>

                                <a href="/admin/products" class="nav-link">
                                    🛒 Manage Products
                                </a>
                                <% } else { %>
                                    <!-- 🔐 Before login -->
                                    <a href="/admin/login" class="nav-link admin-link">
                                        <i class="fas fa-lock"></i> Admin
                                    </a>
                                    <% } %>
            </div>

            <!-- 🍔 Hamburger -->
            <div class="hamburger" id="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </div>

        </div>
    </nav>